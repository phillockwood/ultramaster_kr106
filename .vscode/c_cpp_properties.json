{
    "configurations": [
        {
            "name": "Mac",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "OS_MAC",
                "APP_API",
                "IPLUG_DSP=1",
                "IPLUG_EDITOR=1",
                "IGRAPHICS_NANOVG",
                "IGRAPHICS_METAL,",
                "NOMINMAX"
            ],
            "macFrameworkPath": [
                "/System/Library/Frameworks",
                "/Library/Frameworks"
            ],
            "compilerPath": "/usr/bin/clang",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "clang-x64"
        }
    ],
    "version": 4
}